{
  "name": "@cukies/chain-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx src/cli.ts run",
    "run": "tsx src/cli.ts run",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js run",
    "setup:prod": "node dist/cli.js setup",
    "setup": "tsx src/cli.ts setup",
    "status": "tsx src/cli.ts status",
    "ingest:once": "tsx src/cli.ts ingest-once",
    "import:legacy": "tsx src/cli.ts import-legacy",
    "import:legacy-metadata": "tsx src/cli.ts import-legacy-metadata",
    "project:once": "tsx src/cli.ts project-once",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "mongodb": "^7.0.0",
    "tronweb": "^6.1.0",
    "viem": "^2.31.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.6",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
