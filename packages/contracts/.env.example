BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
DEPLOYER_PRIVATE_KEY=
# Required by mainnet operational/handover scripts and optional for preflight deployer-cleanup checks.
DEPLOYER_ADDRESS=
BSCSCAN_API_KEY=

# Existing deployed tokens / sale parameters.
# Local Hardhat dev uses MockERC20 from tests/simulations.
# BSC testnet ASM/tASM: 0xf93dd40Bf8bD8dDf7C785AA87dc13C3c3FeB6c8C
# BSC mainnet ASM/CONCILIUM: 0x40af8fd127dcd302d7ffa6f37cf5a002e54ac68c
ASM_TOKEN_ADDRESS=
UKI_TOKEN_ADDRESS=
UKI_VESTING_VAULT_ADDRESS=
UKI_PRESALE_ADDRESS=
SALE_TREASURY_ADDRESS=
# Optional. Only set when a multisig/operator will create team/advisor/ecosystem vesting schedules.
ALLOCATION_MANAGER_ADDRESS=
# Required for generic bscTestnet/bsc deploys. In Safe-first flow this is the launch Safe; in deploy:mainnet:operational it is intentionally DEPLOYER_ADDRESS.
SALE_OWNER_ADDRESS=
# Required for production deploy review; choose explicitly instead of relying on deployer fallback.
UKI_INITIAL_SUPPLY_RECEIVER=
# Required only when UKI_INITIAL_SUPPLY_RECEIVER differs from DEPLOYER_ADDRESS and the deploy script must fund the vault.
UKI_INITIAL_SUPPLY_RECEIVER_PRIVATE_KEY=
UKI_INITIAL_SUPPLY=1000000000000000000000000000
SALE_START=
SALE_END=
# Mutable by the launch Safe while ASM price risk is active.
UKI_PER_ASM=100000000000000000000
# 5 ASM minimum purchase / referral activation threshold.
MIN_ASM_PER_PURCHASE=5000000000000000000
# 250M UKI maximum sale allocation from the ecosystem pool.
TOTAL_UKI_FOR_SALE=250000000000000000000000000
# Initial/provisional TGE timestamp. Final value is controlled in VestingVault and must be frozen before claims.
VESTING_START=
VESTING_DURATION=23328000
SALE_ENABLED=false
VESTING_CONFIG_FROZEN=false

# Mainnet operational deploy fixed launch timestamp:
# 2026-06-15 17:00 Europe/Madrid / 15:00 UTC.
# deploy:mainnet:operational enforces this value when SALE_START is provided.
# SALE_START=1781535600

# Mainnet Safe handover phase.
SAFE_OWNER_ADDRESS=
FINAL_ASM_TREASURY_ADDRESS=
UKI_REMAINDER_RECEIVER_ADDRESS=
# Defaults to DEPLOYER_ADDRESS when omitted.
UKI_REMAINDER_SOURCE_ADDRESS=
# Required only when UKI_REMAINDER_SOURCE_ADDRESS differs from DEPLOYER_ADDRESS.
UKI_REMAINDER_SOURCE_PRIVATE_KEY=
# Defaults to true in handover script.
SALE_ENABLED_AFTER_HANDOVER=true

