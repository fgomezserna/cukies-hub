{
  "name": "@cukies/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "security:slither": "slither . --config-file slither.config.json --exclude timestamp,incorrect-equality,costly-loop",
    "clean": "hardhat clean",
    "deploy:local": "hardhat run scripts/deploy-presale.cjs --network hardhat",
    "deploy:testnet": "hardhat run scripts/deploy-presale.production.cjs --network bscTestnet",
    "deploy:testnet:operational": "hardhat run scripts/deploy-testnet-operational.cjs --network bscTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy-presale.production.cjs --network bsc",
    "deploy:mainnet:operational": "hardhat run scripts/deploy-mainnet-operational.cjs --network bsc",
    "handover:mainnet:safe": "hardhat run scripts/safe-handover-mainnet.cjs --network bsc",
    "preflight:presale": "hardhat run scripts/preflight-presale.cjs",
    "simulate:deploy": "hardhat run scripts/simulate-full-deploy.cjs --network hardhat",
    "export:abi": "node scripts/export-abi.cjs",
    "freeze:manifest": "node scripts/print-freeze-manifest.cjs"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-verify": "^2.0.13",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "chai": "^4.5.0",
    "dotenv": "^16.5.0",
    "ethers": "^6.14.0",
    "hardhat": "^2.22.18",
    "solidity-coverage": "^0.8.14",
    "typechain": "^8.3.2"
  }
}
