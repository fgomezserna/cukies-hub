{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter dapp --filter sybil-slayer --filter hyppie-road --filter tower-builder dev",
    "dev:dapp": "pnpm --filter dapp dev",
    "dev:sybil-slayer": "pnpm --filter sybil-slayer dev",
    "dev:hyppie-road": "pnpm --filter hyppie-road dev",
    "dev:tower-builder": "pnpm --filter tower-builder dev",
    "genkit:dev": "pnpm --filter dapp genkit:dev",
    "genkit:watch": "pnpm --filter dapp genkit:watch",
    "dapp": "pnpm --filter dapp",
    "sybil-slayer": "pnpm --filter sybil-slayer",
    "hyppie-road": "pnpm --filter hyppie-road",
    "tower-builder": "pnpm --filter tower-builder",
    "contracts": "pnpm --filter @cukies/contracts",
    "chain-indexer": "pnpm --filter @cukies/chain-indexer",
    "indexer:dev": "pnpm --filter @cukies/chain-indexer run dev",
    "indexer:setup": "pnpm --filter @cukies/chain-indexer run setup",
    "indexer:status": "pnpm --filter @cukies/chain-indexer run status",
    "indexer:ingest": "pnpm --filter @cukies/chain-indexer run ingest:once",
    "indexer:import:legacy": "pnpm --filter @cukies/chain-indexer run import:legacy",
    "indexer:import:metadata": "pnpm --filter @cukies/chain-indexer run import:legacy-metadata",
    "indexer:project": "pnpm --filter @cukies/chain-indexer run project:once",
    "build:dapp": "pnpm --filter dapp build",
    "build:sybil-slayer": "pnpm --filter sybil-slayer build",
    "build:hyppie-road": "pnpm --filter hyppie-road build",
    "build:tower-builder": "pnpm --filter tower-builder build"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8",
    "tailwindcss": "^3.4.1"
  }
}
